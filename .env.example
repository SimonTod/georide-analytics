# =============================================================================
# GeoRide Analytics — Variables d'environnement Docker Compose
#
# Copiez ce fichier en .env et renseignez les valeurs.
# Le fichier .env ne doit jamais être commité (il est dans .gitignore).
# =============================================================================

# --- Base de données PostgreSQL ---
POSTGRES_DB=georide_analytics
POSTGRES_USER=georide
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend ---
# Secret JWT : générer avec `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
GEORIDE_API_URL=https://api.georide.com

# --- Ports exposés sur l'hôte (dev uniquement) ---
BACKEND_PORT=3001
FRONTEND_PORT=5173
DB_PORT=5432

# --- CORS backend (dev) ---
# URL du frontend telle qu'elle est vue depuis le navigateur
FRONTEND_URL=http://localhost:5173

# --- Variables frontend (dev local uniquement) ---
# En production, le proxy nginx achemine /api/* vers le backend (aucune variable requise).
# En dev Docker, BACKEND_URL est défini directement dans docker-compose.dev.yml.
# En dev local (npm run dev), le proxy Vite cible http://localhost:3001 par défaut.
VITE_GEORIDE_API_URL=https://api.georide.com


# =============================================================================
# Variables spécifiques à la production (docker-compose.prod.yml)
# =============================================================================

# Nom de domaine principal (ex: georide.example.com)
# Le backend sera disponible sur api.${DOMAIN}
DOMAIN=georide.example.com

# Email pour la génération des certificats Let's Encrypt
ACME_EMAIL=admin@example.com

# Images Docker construites en CI et poussées dans un registry.
# Exemple avec GitHub Container Registry :
#   BACKEND_IMAGE=ghcr.io/simontod/georide-analytics-backend:latest
#   FRONTEND_IMAGE=ghcr.io/simontod/georide-analytics-frontend:latest
#
# Note : aucun build arg nécessaire — le proxy nginx achemine /api/* vers le
# service backend sur le réseau Docker interne (voir nginx.conf).
BACKEND_IMAGE=ghcr.io/simontod/georide-analytics-backend:latest
FRONTEND_IMAGE=ghcr.io/simontod/georide-analytics-frontend:latest
